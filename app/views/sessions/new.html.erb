<div class="auth-page">
  <div class="auth-card">
    <div class="auth-card__logo">
      <span class="logo-mark">TM</span>
    </div>

    <h1 class="auth-title">Log in</h1>
    <p class="auth-subtitle">Enter your credentials to access the board</p>

    <%= form_with url: login_path, class: "auth-form" do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email", class: "form-label" %>
        <%= f.email_field :email,
              placeholder: "you@example.com",
              class: "form-input",
              autofocus: true,
              autocomplete: "email" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password", class: "form-label" %>
        <%= f.password_field :password,
              placeholder: "••••••••",
              class: "form-input",
              autocomplete: "current-password" %>
      </div>

      <%= f.submit "Log in", class: "btn btn--primary btn--lg auth-submit" %>
    <% end %>

    <p class="auth-footer">
      No account yet? <%= link_to "Sign up", signup_path %>
    </p>
  </div>
</div>
