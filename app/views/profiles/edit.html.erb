<div class="page-header">
  <div>
    <h1 class="page-title">Edit profile</h1>
    <p class="page-subtitle">Update your personal information and avatar</p>
  </div>
</div>

<div class="form-card" style="max-width:680px">

  <%# Current avatar preview %>
  <div class="profile-avatar-row">
    <%= avatar_tag(@user, size: :md, tooltip: false) %>
    <div>
      <p class="profile-avatar-name"><%= @user.display_name %></p>
      <p class="profile-avatar-sub"><%= @user.email %></p>
    </div>
  </div>

  <%# Validation errors %>
  <% if @user.errors.any? %>
    <div class="form-errors">
      <p class="form-errors__title"><%= pluralize(@user.errors.count, "error") %> prevented saving your profile:</p>
      <ul>
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @user, url: profile_path, method: :patch, multipart: true do |f| %>

    <%# ── Name ── %>
    <fieldset class="form-fieldset">
      <legend class="form-legend">Name</legend>
      <div class="form-row">
        <div class="form-group">
          <%= f.label :first_name, "First name", class: "form-label" %>
          <%= f.text_field :first_name, class: "form-input", placeholder: "Jane", autocomplete: "given-name" %>
        </div>
        <div class="form-group">
          <%= f.label :last_name, "Last name", class: "form-label" %>
          <%= f.text_field :last_name, class: "form-input", placeholder: "Doe", autocomplete: "family-name" %>
        </div>
      </div>
      <div class="form-group">
        <%= f.label :nickname, class: "form-label" %>
        <span class="form-hint">Required — shown on cards and the board</span>
        <%= f.text_field :nickname, class: "form-input", autocomplete: "nickname", required: true %>
      </div>
    </fieldset>

    <%# ── Account ── %>
    <fieldset class="form-fieldset">
      <legend class="form-legend">Account</legend>
      <div class="form-group">
        <%= f.label :email, class: "form-label" %>
        <span class="form-hint">Format: name@domain.tld — stored in lowercase</span>
        <%= f.email_field :email, class: "form-input", autocomplete: "email", required: true %>
      </div>
      <div class="form-row">
        <div class="form-group">
          <%= f.label :password, class: "form-label" %>
          <span class="form-hint">Leave blank to keep your current password (min. 6 chars)</span>
          <%= f.password_field :password, class: "form-input", autocomplete: "new-password", placeholder: "••••••" %>
        </div>
        <div class="form-group">
          <%= f.label :password_confirmation, "Confirm password", class: "form-label" %>
          <span class="form-hint">&nbsp;</span>
          <%= f.password_field :password_confirmation, class: "form-input", autocomplete: "new-password", placeholder: "••••••" %>
        </div>
      </div>
    </fieldset>

    <%# ── Avatar ── %>
    <fieldset class="form-fieldset">
      <legend class="form-legend">Avatar</legend>
      <%= render "shared/avatar_upload", f: f %>
    </fieldset>

    <div class="form-actions">
      <%= f.submit "Save changes", class: "btn btn--primary" %>
      <%= link_to "Cancel", root_path, class: "btn btn--ghost" %>
    </div>

  <% end %>
</div>
