<div class="auth-page">
  <div class="auth-card" style="max-width:480px">
    <div class="auth-card__logo">
      <span class="logo-mark">TM</span>
    </div>

    <h1 class="auth-title">Create account</h1>
    <p class="auth-subtitle">Join the board and start tracking tasks</p>

    <% if @user.errors.any? %>
      <div class="form-errors">
        <p class="form-errors__title">
          <%= pluralize(@user.errors.count, "error prevented", "errors prevented") %> sign-up:
        </p>
        <ul>
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: signup_path, multipart: true, class: "auth-form" do |f| %>

      <%# Name row %>
      <div class="form-row">
        <div class="form-group">
          <%= f.label :first_name, "First name", class: "form-label" %>
          <%= f.text_field :first_name, class: "form-input", placeholder: "Jane",
                autocomplete: "given-name", autofocus: true %>
        </div>
        <div class="form-group">
          <%= f.label :last_name, "Last name", class: "form-label" %>
          <%= f.text_field :last_name, class: "form-input", placeholder: "Doe",
                autocomplete: "family-name" %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :nickname, "Nickname *", class: "form-label" %>
        <span class="form-hint">Required — shown on the board</span>
        <%= f.text_field :nickname, class: "form-input", placeholder: "e.g. Alice",
              autocomplete: "nickname" %>
      </div>

      <div class="form-group">
        <%= f.label :email, "Email *", class: "form-label" %>
        <span class="form-hint">Format: name@domain.tld</span>
        <%= f.email_field :email, class: "form-input", placeholder: "you@example.com",
              autocomplete: "email" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password *", class: "form-label" %>
        <span class="form-hint">At least 6 characters</span>
        <%= f.password_field :password, class: "form-input", placeholder: "••••••••",
              autocomplete: "new-password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm password *", class: "form-label" %>
        <%= f.password_field :password_confirmation, class: "form-input",
              placeholder: "••••••••", autocomplete: "new-password" %>
      </div>

      <%# Avatar %>
      <div class="form-group">
        <%= f.label :avatar_url, "Avatar", class: "form-label" %>
        <%= render "shared/avatar_upload", f: f %>
      </div>

      <%= f.submit "Create account", class: "btn btn--primary btn--lg auth-submit" %>
    <% end %>

    <p class="auth-footer">
      Already have an account? <%= link_to "Log in", login_path %>
    </p>
  </div>
</div>
